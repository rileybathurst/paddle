{
  "name": "@rileybathurst/paddle",
  "private": false,
  "version": "1.17.5",
  "type": "module",
  "scripts": {
    "dev": "tsc --noEmit && stay-gold && vite",
    "dirty": "vite",
    "build": "tsc --noEmit && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "storybook": "tsc --noEmit && stay-gold && storybook dev -p 6006",
    "storybook-dirty": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "release": "bun version patch && bun login && bun publish",
    "stay-gold": "stay-gold"
  },
  "dependencies": {
    "color-cards": "^1.0.18",
    "gatsby": "^5.16.1",
    "gatsby-plugin-image": "^3.16.0",
    "postcss-dark-theme-class": "^2.0.0",
    "react": "^19.2.7",
    "react-aria-components": "^1.19.0",
    "react-dom": "^19.2.7",
    "react-inlinesvg": "^4.5.0",
    "react-markdown": "^10.1.0",
    "stay-gold": "^1.5.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@chromatic-com/storybook": "^5.2.1",
    "@faker-js/faker": "^10.5.0",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-links": "^10.4.6",
    "@storybook/addon-themes": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint-plugin-storybook": "^10.4.6",
    "storybook": "^10.4.6",
    "typescript": "^6.0.3",
    "vite": "^8.1.3"
  },
  "description": "building blocks",
  "main": "src/index.tsx",
  "module": "src/index.tsx",
  "author": "Riley Bathurst <riley@rileybathurst.com> (http://rileybathurst.com/)",
  "license": "ISC",
  "files": [
    "src/*",
    "!src/stories"
  ],
  "overrides": {
    "storybook": "$storybook",
    "@types/reach__router": {
      "@types/react": "19.2.17"
    }
  }
}
